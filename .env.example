# Токен бота от @BotFather
BOT_TOKEN=123456:replace-me

# Подключение к БД (локально; внутри docker compose переопределяется)
DATABASE_URL=postgresql+asyncpg://adder:adder@localhost:5433/adder_splitter

# FSM-storage. Пусто/не задано -> MemoryStorage (диалоги не переживают рестарт)
# REDIS_URL=redis://localhost:6379/0

# Для контейнера postgres в docker compose
POSTGRES_USER=adder
POSTGRES_PASSWORD=adder
POSTGRES_DB=adder_splitter
